{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash

# System packages (CLI tools managed by mise are excluded)
FORMULAE=(
    coreutils
    ffmpeg
    git
    gnupg
    libgit2
    mise
    pcre
    pinentry-mac
    tmux
    watch
    zsh
    zsh-autosuggestions
    zsh-fast-syntax-highlighting
)

# GUI Applications
CASKS=(
    alt-tab
    arc
    betterdisplay
    claude
    deepl
    discord
    excalidrawz
    font-cascadia-code-nf
    github
    google-chrome
    iina
    jetbrains-toolbox
    karabiner-elements
    music-decoy
    obsidian
    orbstack
    postman
    raycast
    rectangle
    shottr
    slack
    tailscale
    warp
    zed
)

# Install Homebrew
if ! command -v brew &> /dev/null; then
    printf '\n\e[33mHomebrew not found.\e[0m Installing Homebrew...\n'
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
else
    printf '\n\e[0mHomebrew found. Continuing...\n'
fi

# Install Oh-my-zsh
if [ ! -d ~/.oh-my-zsh ]; then
    printf '\n\e[33mOh-my-zsh not found.\e[0m Installing Oh-my-zsh...\n'
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
else
    printf '\n\e[0mOh-my-zsh found. Continuing...\n'
fi

# Update Homebrew
printf '\nUpdating Homebrew...\n'
brew update

# Install formulae
printf '\nInstalling formulae...\n'
for formula in "${FORMULAE[@]}"; do
    brew list --formula "$formula" &>/dev/null || brew install "$formula"
done

# Install casks
printf '\nInstalling casks...\n'
for cask in "${CASKS[@]}"; do
    brew list --cask "$cask" &>/dev/null || brew install --cask "$cask"
done

# Cleanup
printf '\nCleaning up...\n'
brew cleanup

# After this, run: mise install
printf '\n\e[32mDone!\e[0m Run "mise install" to install CLI tools.\n'

{{ end -}}
