# This is Git's per-user configuration file.
[user]
# Please adapt and uncomment the following lines:
	name = doxxx93
	email = doxxx93@gmail.com
	signingkey = /Users/stclab/.ssh/id_ed25519.pub
[commit]
	gpgsign = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[includeIf "gitdir:~/doxxx/"]
  path = ~/.gitconfig-doxxx
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = /Users/stclab/.ssh/allowed_signers
[includeIf "gitdir:~/work/"]
	path = /Users/stclab/.gitconfig-stclab
[credential "https://github.com"]
	helper = !$HOME/.local/share/mise/shims/gh auth git-credential
[credential "https://gist.github.com"]
	helper = !$HOME/.local/share/mise/shims/gh auth git-credential
